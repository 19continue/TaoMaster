                                                               FontFamily="Consolas"
                                                               FontSize="12.5"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               TextWrapping="Wrap">
                                                        <Run Tag="settingsMirrorOfLabel"
                                                             Text="mirrorOf" />
                                                        <Run Text=": " />
                                                        <Run Text="{Binding MirrorOf}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <WrapPanel Margin="0,16,0,0">
                                        <Button x:Name="LegacyUpdateSelectedMirrorButton"
                                                Content="Update Selected Mirror"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnUpdateSelectedMirrorClicked" />
                                        <Button Tag="removeSelectedMirrorButton"
                                                Content="Remove Selected Mirror"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnRemoveSelectedMirrorClicked" />
                                        <Button x:Name="LegacySaveMavenSettingsButton"
                                                Content="Save Maven Configuration"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Click="OnSaveMavenSettingsClicked" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
                <ScrollViewer x:Name="MavenConfigPage"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*" />
                            <ColumnDefinition Width="0.65*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,24,0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Tag="settingsMavenConfigTitle"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Text="Maven Configuration" />
                                    <TextBlock x:Name="MavenConfigIntroTextBlock"
                                               Margin="0,10,0,16"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="Configure settings.xml, toolchains.xml, the local repository path, and mirror XML for your Maven and IDE environment." />

                                    <TextBlock x:Name="SettingsConfigurationScopeLabelTextBlock"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="Configuration Scope" />
                                    <ComboBox x:Name="MavenConfigurationScopeComboBox"
                                              Margin="0,8,0,0"
                                              Height="36"
                                              DisplayMemberPath="DisplayName"
                                              Style="{StaticResource InputComboBoxStyle}"
                                              SelectionChanged="OnMavenConfigurationScopeSelectionChanged" />
                                    <TextBlock x:Name="MavenConfigurationScopeHintTextBlock"
                                               Margin="0,10,0,16"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="User scope writes to ~/.m2. Global scope writes to the selected Maven installation under conf." />

                                    <TextBlock Tag="settingsMavenSettingsPathLabel"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="settings.xml Path" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="MavenSettingsFilePathTextBox"
                                                 Grid.Column="0"
                                                 Height="36"
                                                 Margin="0,0,10,0"
                                                 LostFocus="OnMavenSettingsFilePathLostFocus"
                                                 Style="{StaticResource InputTextBoxStyle}"
                                                 VerticalContentAlignment="Center" />
                                        <Button x:Name="BrowseMavenSettingsFileButton"
                                                Grid.Column="1"
                                                Tag="browseButton"
                                                Content="Browse"
                                                Width="88"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnBrowseMavenSettingsFileClicked" />
                                        <Button Grid.Column="2"
                                                x:Name="OpenMavenSettingsFileButton"
                                                Content="Open"
                                                Width="88"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnOpenMavenSettingsFileClicked" />
                                    </Grid>
                                    <WrapPanel Margin="0,12,0,16">
                                        <Button x:Name="LoadMavenSettingsButton"
                                                Content="Read Mirrors From Config File"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnLoadMavenSettingsClicked" />
                                    </WrapPanel>

                                    <TextBlock x:Name="SettingsToolchainsFilePathLabelTextBlock"
                                               Margin="0,16,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="toolchains.xml Path" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="MavenToolchainsFilePathTextBox"
                                                 Grid.Column="0"
                                                 Height="36"
                                                 Margin="0,0,10,0"
                                                 LostFocus="OnMavenToolchainsFilePathLostFocus"
                                                 Style="{StaticResource InputTextBoxStyle}"
                                                 VerticalContentAlignment="Center" />
                                        <Button x:Name="BrowseMavenToolchainsFileButton"
                                                Grid.Column="1"
                                                Tag="browseButton"
                                                Content="Browse"
                                                Width="88"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnBrowseMavenToolchainsFileClicked" />
                                        <Button Grid.Column="2"
                                                x:Name="OpenMavenToolchainsFileButton"
                                                Content="Open"
                                                Width="88"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnOpenMavenToolchainsFileClicked" />
                                    </Grid>

                                    <WrapPanel Margin="0,12,0,0">
                                        <Button x:Name="LoadMavenToolchainsButton"
                                                Content="Read Toolchains From Config File"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnLoadMavenToolchainsClicked" />
                                    </WrapPanel>

                                    <TextBlock x:Name="ToolchainsJdkSelectorLabelTextBlock"
                                               Margin="0,18,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="Insert Installed JDK" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="ToolchainsJdkComboBox"
                                                  Grid.Column="0"
                                                  Height="36"
                                                  Margin="0,0,10,0"
                                                  DisplayMemberPath="DisplayName"
                                                  Style="{StaticResource InputComboBoxStyle}" />
                                        <Button x:Name="InsertSelectedJdkToolchainButton"
                                                Grid.Column="1"
                                                Content="Insert Selected JDK"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnInsertSelectedJdkToolchainClicked" />
                                    </Grid>

                                    <TextBlock x:Name="ToolchainsXmlEditorLabelTextBlock"
                                               Margin="0,18,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="Toolchains XML" />
                                    <TextBox x:Name="ToolchainsXmlEditorTextBox"
                                             Margin="0,8,0,0"
                                             MinHeight="240"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             HorizontalScrollBarVisibility="Auto"
                                             VerticalScrollBarVisibility="Auto"
                                             FontFamily="Consolas"
                                             FontSize="12.5"
                                             TextWrapping="NoWrap"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             TextChanged="OnToolchainsXmlEditorTextChanged" />
                                    <TextBlock x:Name="ToolchainsXmlEditorHintTextBlock"
                                               Margin="0,10,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="Edit the full toolchains.xml here. TaoMaster can insert installed JDK entries and keeps the file formatted when saving." />

                                    <TextBlock Margin="0,16,0,0"
                                               Tag="settingsMavenLocalRepoLabel"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="Local Repository" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="MavenLocalRepositoryPathTextBox"
                                                 Grid.Column="0"
                                                 Height="36"
                                                 Margin="0,0,10,0"
                                                 Style="{StaticResource InputTextBoxStyle}"
                                                 VerticalContentAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Tag="browseButton"
                                                Content="Browse"
                                                Width="88"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnBrowseMavenLocalRepositoryClicked" />
                                    </Grid>
                                    <CheckBox x:Name="MavenRepositoryMigrationCheckBox"
                                              Margin="0,12,0,0"
                                              Content="Move existing local repository contents when the repository directory changes." />

                                    <TextBlock Margin="0,18,0,0"
                                               Tag="settingsMavenMirrorTitle"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="Built-in Mirrors" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="BuiltInMavenMirrorComboBox"
                                                  Grid.Column="0"
                                                  Height="36"
                                                  Margin="0,0,10,0"
                                                  DisplayMemberPath="Name"
                                                  Style="{StaticResource InputComboBoxStyle}" />
                                        <Button x:Name="AddBuiltInMirrorButton"
                                                Grid.Column="1"
                                                Content="Insert Built-in Mirror"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnAddBuiltInMirrorClicked" />
                                    </Grid>

                                    <TextBlock x:Name="MirrorXmlEditorLabelTextBlock"
                                               Margin="0,18,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="Mirror XML" />
                                    <TextBox x:Name="MavenMirrorsXmlEditorTextBox"
                                             Margin="0,8,0,0"
                                             MinHeight="320"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             HorizontalScrollBarVisibility="Auto"
                                             VerticalScrollBarVisibility="Auto"
                                             FontFamily="Consolas"
                                             FontSize="12.5"
                                             TextWrapping="NoWrap"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             TextChanged="OnMavenMirrorsXmlEditorTextChanged" />
                                    <TextBlock x:Name="MavenMirrorsXmlEditorHintTextBlock"
                                               Margin="0,10,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="Edit the &lt;mirrors&gt; XML directly. TaoMaster only updates the mirrors node and localRepository value in settings.xml." />

                                    <WrapPanel Margin="0,18,0,0">
                                        <Button x:Name="SaveMavenSettingsButton"
                                                Content="Save Maven Configuration"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Click="OnSaveMavenSettingsClicked" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock x:Name="MavenConfigTargetTitleTextBlock"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Text="Current Target" />
                                    <TextBlock x:Name="MavenConfigTargetDescriptionTextBlock"
                                               Margin="0,10,0,16"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="Global scope writes to the selected Maven installation. User scope writes to the current user's .m2 directory." />
                                    <TextBlock x:Name="MavenConfigCurrentScopeLabelTextBlock"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="Scope" />
                                    <TextBlock x:Name="MavenConfigCurrentScopeTextBlock"
                                               Margin="0,8,0,0"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="User Configuration" />
                                    <TextBlock x:Name="MavenConfigCurrentMavenLabelTextBlock"
                                               Margin="0,16,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="Target Maven" />
                                    <TextBlock x:Name="MavenConfigCurrentMavenTextBlock"
                                               Margin="0,8,0,0"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="(none)" />
                                    <TextBlock x:Name="MavenConfigCurrentMavenPathTextBlock"
                                               Margin="0,8,0,0"
                                               FontFamily="Consolas"
                                               FontSize="12.5"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="MavenConfigEffectiveSettingsLabelTextBlock"
                                               Margin="0,16,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="Effective settings.xml" />
                                    <TextBlock x:Name="MavenConfigEffectiveSettingsPathTextBlock"
                                               Margin="0,8,0,0"
                                               FontFamily="Consolas"
                                               FontSize="12.5"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="MavenConfigEffectiveToolchainsLabelTextBlock"
                                               Margin="0,16,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="Effective toolchains.xml" />
                                    <TextBlock x:Name="MavenConfigEffectiveToolchainsPathTextBlock"
                                               Margin="0,8,0,0"
                                               FontFamily="Consolas"
                                               FontSize="12.5"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock x:Name="ConfiguredJdkToolchainsTitleTextBlock"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Text="Current JDK Toolchains" />
                                    <TextBlock x:Name="ConfiguredJdkToolchainsHintTextBlock"
                                               Margin="0,10,0,16"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="Select a toolchain entry, then update it with the installed JDK selected on the left or remove it directly." />
                                    <ListBox x:Name="ConfiguredJdkToolchainsListBox"
                                             MinHeight="280"
                                             Style="{StaticResource CleanListBoxStyle}"
                                             ItemContainerStyle="{StaticResource SelectablePanelListItemStyle}"
                                             SelectionChanged="OnConfiguredJdkToolchainsSelectionChanged"
                                             PreviewMouseWheel="OnEmbeddedListPreviewMouseWheel">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,14,16,14">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource InkBrush}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding Detail}"
                                                               Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock Margin="0,8,0,0"
                                                               FontFamily="Consolas"
                                                               FontSize="12.5"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               Text="{Binding JdkHome}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <WrapPanel Margin="0,16,0,0">
                                        <Button x:Name="UpdateSelectedJdkToolchainButton"
                                                Content="Update Selected Toolchain"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnUpdateSelectedJdkToolchainClicked" />
                                        <Button x:Name="RemoveSelectedJdkToolchainButton"
                                                Content="Remove Selected Toolchain"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Click="OnRemoveSelectedJdkToolchainClicked" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock x:Name="MavenConfigEditorGuideTitleTextBlock"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Text="Editing Guide" />
                                    <TextBlock x:Name="MavenConfigEditorGuideTextBlock"
                                               Margin="0,10,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="Use 'Read Mirrors From Config File' to load the current mirrors, edit the XML directly, then save. Opening settings.xml or toolchains.xml will normalize the file format before launching Notepad." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
                <StackPanel Visibility="Collapsed">
                    <TextBox x:Name="CustomMavenMirrorNameTextBox" />
                    <TextBox x:Name="CustomMavenMirrorUrlTextBox" />
                    <TextBox x:Name="CustomMavenMirrorOfTextBox" />
                    <ListBox x:Name="ConfiguredMavenMirrorsListBox" />
                    <Button x:Name="ImportMirrorXmlButton" Visibility="Collapsed" />
                    <Button x:Name="UpdateSelectedMirrorButton" />
                    <ComboBox x:Name="MavenDownloadSourceComboBox" />
                    <TextBlock x:Name="MavenDownloadSourceBaseUrlTextBlock" />
                    <TextBox x:Name="CustomMavenDownloadSourceNameTextBox" />
                    <TextBox x:Name="CustomMavenDownloadSourceUrlTextBox" />
                </StackPanel>
                <Border x:Name="BusyOverlay"
                        Background="#88E8ECE8"
                        Visibility="Collapsed"
                        Panel.ZIndex="30">
                    <Grid>
                        <Border Width="360"
                                Padding="24"
                                CornerRadius="18"
                                Background="#11201A"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock x:Name="BusyTitleTextBlock"
                                           Tag="workingTitle"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#F6FBF8"
                                           Text="Working" />
                                <TextBlock x:Name="BusyTextBlock"
                                           Margin="0,12,0,0"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#EAF3EF"
                                           TextWrapping="Wrap"
                                           Text="Please wait..." />
                                <TextBlock x:Name="BusyDetailTextBlock"
                                           Margin="0,8,0,0"
                                           Foreground="#C7D5CE"
                                           FontSize="12.5"
                                           TextWrapping="Wrap"
                                           Text="Preparing..." />
                                <ProgressBar x:Name="BusyProgressBar"
                                             Margin="0,16,0,0"
                                             Height="8"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="12"
                                             IsIndeterminate="True"
                                             Foreground="{StaticResource AccentBrush}"
                                             Background="#294237"
                                             BorderThickness="0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
