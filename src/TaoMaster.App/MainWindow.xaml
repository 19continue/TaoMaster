<Window x:Class="TaoMaster.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TaoMaster"
        Icon="Assets/logo.png"
        Width="1460"
        Height="940"
        MinWidth="1260"
        MinHeight="820"
        Background="#F4F6F2"
        FontFamily="Microsoft YaHei UI"
        Loaded="OnLoaded">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#F4F6F2" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FCFDFB" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#F1F4EF" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#16221D" />
        <SolidColorBrush x:Key="SidebarCardBrush" Color="#1C2D25" />
        <SolidColorBrush x:Key="SidebarHoverBrush" Color="#21372D" />
        <SolidColorBrush x:Key="InkBrush" Color="#1B2621" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6D7B73" />
        <SolidColorBrush x:Key="SoftLineBrush" Color="#DCE5DD" />
        <SolidColorBrush x:Key="AccentBrush" Color="#287A63" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E0EFE8" />
        <SolidColorBrush x:Key="AccentSurfaceBrush" Color="#F3F8F4" />
        <SolidColorBrush x:Key="WarningBrush" Color="#C88A36" />
        <SolidColorBrush x:Key="DangerBrush" Color="#BF6557" />
        <SolidColorBrush x:Key="InfoBrush" Color="#3A6F9E" />
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Direction="270"
                          Color="#0F241A"
                          Opacity="0.08" />
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,24" />
            <Setter Property="Effect" Value="{StaticResource CardShadow}" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>
        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftLineBrush}" />
        </Style>
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#F8EEEC" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="#F1D9D4" />
        </Style>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#C7D5CE" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <Grid>
                                <Border x:Name="NavRail"
                                        Width="3"
                                        Margin="0,10,0,10"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding BorderBrush}"
                                        CornerRadius="2" />
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="13" />
            <EventSetter Event="PreviewMouseWheel" Handler="OnComboBoxPreviewMouseWheel" />
        </Style>
        <Style x:Key="CleanListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style x:Key="SelectablePanelListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Grid>
                                <Border x:Name="SelectionRail"
                                        Width="4"
                                        Margin="10,12,0,12"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />
                                <ContentPresenter Margin="20,0,0,0"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#CFE1D7" />
                                <Setter TargetName="SelectionRail" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="268" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="20"
                Padding="20"
                CornerRadius="20"
                Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel x:Name="SidebarHeaderPanel">
                    <Border Width="72"
                            Height="72"
                            CornerRadius="20"
                            Background="#1E362B"
                            HorizontalAlignment="Left">
                        <Image Source="Assets/logo.png"
                               Margin="9"
                               Stretch="Uniform" />
                    </Border>

                    <TextBlock x:Name="ProductNameTextBlock"
                               Margin="0,18,0,0"
                               FontFamily="Bahnschrift SemiCondensed"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="#F6FBF8"
                               Text="TaoMaster" />
                    <TextBlock x:Name="ProductVersionTextBlock"
                               Margin="0,4,0,0"
                               FontFamily="Bahnschrift SemiCondensed"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#9FB3AA"
                               Text="v1.0.0" />
                    <TextBlock Margin="0,12,0,0"
                               Tag="headerSubtitle"
                               FontSize="13"
                               Foreground="#C7D5CE"
                               Text="Windows toolchain manager for JDK and Maven" />
                    <TextBlock Margin="0,10,0,0"
                               Tag="headerDescription"
                               FontSize="12.5"
                               Foreground="#8EA298"
                               TextWrapping="Wrap"
                               Text="Local discovery, managed installs, global switching, and Maven/JDK consistency checks in one desktop surface." />
                </StackPanel>
                <StackPanel x:Name="SidebarNavPanel"
                            Grid.Row="1"
                            Margin="0,30,0,0">
                    <TextBlock Tag="sidebarNavigationLabel"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#7E958B"
                               Text="Navigation" />

                    <Button x:Name="DashboardNavButton"
                            Tag="navDashboard"
                            Content="Dashboard"
                            Style="{StaticResource NavButtonStyle}"
                            Click="OnDashboardNavClicked" />
                    <Button x:Name="VersionsNavButton"
                            Tag="navVersions"
                            Content="Versions"
                            Style="{StaticResource NavButtonStyle}"
                            Click="OnVersionsNavClicked" />
                    <Button x:Name="ProjectsNavButton"
                            Tag="navProjects"
                            Content="Projects"
                            Style="{StaticResource NavButtonStyle}"
                            Click="OnProjectsNavClicked" />
                    <Button x:Name="DiagnosticsNavButton"
                            Tag="navDiagnostics"
                            Content="Diagnostics"
                            Style="{StaticResource NavButtonStyle}"
                            Click="OnDiagnosticsNavClicked" />
                    <Button x:Name="SettingsNavButton"
                            Tag="navSettings"
                            Content="Settings"
                            Style="{StaticResource NavButtonStyle}"
                            Click="OnSettingsNavClicked" />
                    <Button x:Name="MavenConfigNavButton"
                            Content="Maven Config"
                            Style="{StaticResource NavButtonStyle}"
                            Click="OnMavenConfigNavClicked" />
                </StackPanel>
                <Border x:Name="SidebarFooterCard"
                        Grid.Row="2"
                        Padding="16"
                        CornerRadius="14"
                        Background="{StaticResource SidebarCardBrush}">
                    <StackPanel>
                        <TextBlock Tag="sidebarWorkspaceLabel"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8EA298"
                                   Text="Workspace" />
                        <TextBlock x:Name="SidebarWorkspaceTextBlock"
                                   Margin="0,8,0,0"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="#F6FBF8"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,12,0,0"
                                   Tag="sidebarScopeLabel"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8EA298"
                                   Text="Current Scope" />
                        <TextBlock x:Name="SidebarScopeTextBlock"
                                   Margin="0,8,0,0"
                                   Foreground="#D8EFE6"
                                   Text="Global" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="2"
              Margin="0,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="TopHeaderCard"
                    Padding="20"
                    CornerRadius="18"
                    Background="{StaticResource PanelBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="PageTitleTextBlock"
                                   FontFamily="Bahnschrift SemiCondensed"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}"
                                   Text="Dashboard" />
                        <TextBlock x:Name="PageDescriptionTextBlock"
                                   Margin="0,10,0,0"
                                   FontSize="13.5"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Text="Current environment, quick switching, and health feedback are grouped here." />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right">
                        <WrapPanel HorizontalAlignment="Right">
                            <Border x:Name="HeaderScopeBadgeBorder"
                                    Margin="0,0,10,8"
                                    Padding="12,7"
                                    CornerRadius="999"
                                    Background="{StaticResource AccentSoftBrush}">
                                <TextBlock x:Name="HeaderScopeBadgeTextBlock"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="Global" />
                            </Border>
                            <Border x:Name="HeaderEnvironmentBadgeBorder"
                                    Margin="0,0,0,8"
                                    Padding="12,7"
                                    CornerRadius="999"
                                    Background="#E6EEF7">
                                <TextBlock x:Name="HeaderEnvironmentBadgeTextBlock"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InfoBrush}"
                                           Text="Check Needed" />
                            </Border>
                        </WrapPanel>
                        <TextBlock x:Name="HeaderEnvironmentHintTextBlock"
                                   HorizontalAlignment="Right"
                                   FontSize="12.5"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="Run Doctor to verify shell and PATH state." />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="ContentHost"
                  Grid.Row="1"
                  Margin="0,24,0,0">
                <ScrollViewer x:Name="DashboardPage"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Tag="dashboardCurrentJdkTitle"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Text="Current JDK" />
                                    <TextBlock x:Name="DashboardCurrentJdkTextBlock"
                                               Margin="0,14,0,0"
                                               FontSize="26"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="(none)" />
                                    <TextBlock x:Name="DashboardCurrentJdkPathTextBlock"
                                               Margin="0,10,0,0"
                                               FontFamily="Consolas"
                                               FontSize="12.5"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0"
                                    Grid.Column="2"
                                    Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Tag="dashboardCurrentMavenTitle"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Text="Current Maven" />
                                    <TextBlock x:Name="DashboardCurrentMavenTextBlock"
                                               Margin="0,14,0,0"
                                               FontSize="26"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="(none)" />
                                    <TextBlock x:Name="DashboardCurrentMavenPathTextBlock"
                                               Margin="0,10,0,0"
                                               FontFamily="Consolas"
                                               FontSize="12.5"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Tag="dashboardScopeTitle"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Text="Active Scope" />
                                    <Border Margin="0,14,0,0"
                                            Padding="10,6"
                                            CornerRadius="999"
                                            Background="{StaticResource AccentSoftBrush}"
                                            HorizontalAlignment="Left">
                                        <TextBlock x:Name="DashboardScopeTextBlock"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Text="Global" />
                                    </Border>
                                    <TextBlock x:Name="DashboardScopeDetailTextBlock"
                                               Margin="0,12,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="Project rules are not enabled yet." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="2"
                                    Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Tag="dashboardEnvironmentTitle"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Text="Environment Status" />
                                    <Border x:Name="DashboardEnvironmentBadgeBorder"
                                            Margin="0,14,0,0"
                                            Padding="10,6"
                                            CornerRadius="999"
                                            Background="#E6EEF7"
                                            HorizontalAlignment="Left">
                                        <TextBlock x:Name="DashboardEnvironmentTextBlock"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource InfoBrush}"
                                                   Text="Check Needed" />
                                    </Border>
                                    <TextBlock x:Name="DashboardEnvironmentDetailTextBlock"
                                               Margin="0,12,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="Run Doctor to verify shell and PATH state." />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="0.8*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,18,0">
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Tag="dashboardQuickActionsTitle"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   Text="Quick Switch" />
                                        <TextBlock Margin="0,10,0,16"
                                                   Tag="dashboardQuickActionsDescription"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   Text="Select a target version and switch immediately. Versions are applied at global scope." />

                                        <TextBlock Tag="dashboardQuickJdkLabel"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource InkBrush}"
                                                   Text="Quick Switch JDK" />
                                        <Grid Margin="0,10,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <ComboBox x:Name="DashboardJdkComboBox"
                                                      Grid.Column="0"
                                                      Height="36"
                                                      Margin="0,0,10,0"
                                                      Style="{StaticResource InputComboBoxStyle}"
                                                      DisplayMemberPath="DisplayName" />
                                            <Button Grid.Column="1"
                                                    Tag="useSelectedJdkButton"
                                                    Content="Use Selected JDK"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="OnDashboardUseSelectedJdkClicked" />
                                        </Grid>

                                        <TextBlock Tag="dashboardQuickMavenLabel"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource InkBrush}"
                                                   Text="Quick Switch Maven" />
                                        <Grid Margin="0,10,0,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <ComboBox x:Name="DashboardMavenComboBox"
                                                      Grid.Column="0"
                                                      Height="36"
                                                      Margin="0,0,10,0"
                                                      Style="{StaticResource InputComboBoxStyle}"
                                                      DisplayMemberPath="DisplayName" />
                                            <Button Grid.Column="1"
                                                    Tag="useSelectedMavenButton"
                                                    Content="Use Selected Maven"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="OnDashboardUseSelectedMavenClicked" />
                                        </Grid>

                                        <WrapPanel>
                                            <Button Tag="navVersions"
                                                    Content="Versions"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Click="OnVersionsNavClicked" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Tag="dashboardRecentActivityTitle"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   Text="Recent Activity" />
                                        <TextBlock Margin="0,10,0,14"
                                                   Tag="dashboardRecentActivityDescription"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   Text="Recent changes and verification steps in this app session." />

                                        <ListBox x:Name="ActivityListBox"
                                                 MinHeight="220"
                                                 Style="{StaticResource CleanListBoxStyle}"
                                                 PreviewMouseWheel="OnEmbeddedListPreviewMouseWheel">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="14"
                                                            CornerRadius="14"
                                                            Background="{StaticResource PanelAltBrush}">
                                                        <TextBlock Text="{Binding}"
                                                                   Foreground="{StaticResource InkBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Tag="dashboardHealthTitle"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   Text="Environment Health" />
                                        <TextBlock Margin="0,10,0,16"
                                                   Tag="dashboardHealthDescription"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   Text="Key checks are grouped by runtime, shell path, and verification state." />
                                        <Border Background="{StaticResource PanelAltBrush}"
                                                CornerRadius="16"
                                                Padding="14"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Tag="healthJavaLabel"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource InkBrush}"
                                                               Text="Java Available" />
                                                    <TextBlock x:Name="JavaHealthHintTextBlock"
                                                               Margin="0,6,0,0"
                                                               Style="{StaticResource BodyTextStyle}" />
                                                </StackPanel>
                                                <Border x:Name="JavaHealthBadgeBorder"
                                                        Grid.Column="1"
                                                        Padding="10,6"
                                                        CornerRadius="999"
                                                        Background="#E6EEF7"
                                                        VerticalAlignment="Top">
                                                    <TextBlock x:Name="JavaHealthBadgeTextBlock"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource InfoBrush}"
                                                               Text="Pending" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <Border Background="{StaticResource PanelAltBrush}"
                                                CornerRadius="16"
                                                Padding="14"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
