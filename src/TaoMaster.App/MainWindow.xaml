                                            <DataTemplate>
                                                <StackPanel Margin="0,4,12,4">
                                                    <TextBlock FontSize="18"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource InkBrush}"
                                                               Text="{Binding Name}" />
